# Copy to .env and fill in. NEVER commit the real .env (it is git-ignored).
# All secrets are injected at runtime; nothing sensitive is baked into images or git.

# ---- Domain & TLS (Caddy auto-provisions Let's Encrypt) ----
DOMAIN=books.example.co.id
ACME_EMAIL=admin@example.co.id

# ---- nopCommerce build ----
NOP_VERSION=release-4.90.4

# ---- PostgreSQL ----
POSTGRES_DB=nopcommerce
POSTGRES_USER=nopapp
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ---- nopCommerce DB connection (used only if NOP_SEED_DATASETTINGS=true) ----
NOP_DATA_PROVIDER=postgresql
NOP_DB_HOST=postgres
NOP_DB_PORT=5432
# Default OFF -> run the install wizard once (recommended). Set true for headless seeding.
NOP_SEED_DATASETTINGS=false

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_ENABLED=true
# memory = fastest for a single app instance; redis = multi-instance / cross-restart cache (§3.5)
REDIS_CACHE_TYPE=redis

# ---- Backups (retention; also push /backups off-site) ----
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6
