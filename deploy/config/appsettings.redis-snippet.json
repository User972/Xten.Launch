{
  "_comment": "Merge these blocks into App_Data/appsettings.json (written by the install wizard), then restart. Reference: blueprint §3.2. The Redis password is better supplied via the DistributedCacheConfig__ConnectionString env var in docker-compose so it stays out of this file.",

  "CacheConfig": {
    "DefaultCacheTime": 60,
    "ShortTermCacheTime": 3,
    "BundledFilesCacheTime": 120
  },
  "HostingConfig": {
    "UseProxy": true,
    "KnownProxies": ""
  },
  "DistributedCacheConfig": {
    "DistributedCacheType": "redis",
    "Enabled": true,
    "ConnectionString": "redis:6379,password=__SET_VIA_ENV_OR_SECRET__,ssl=False,abortConnect=False",
    "SchemaName": "",
    "InstanceName": "nop_"
  },
  "PluginConfig": {
    "UseUnsafeLoadAssembly": true
  },
  "CommonConfig": {
    "UseSessionStateTempDataProvider": false,
    "StaticFilesCacheControl": "public,max-age=604800",
    "SupportPreviousNopcommerceVersions": false
  }
}
