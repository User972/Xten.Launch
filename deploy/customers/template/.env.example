# Per-tenant config. new-customer.sh generates the real .env (with a random POSTGRES_PASSWORD).
# This example documents the variables; you normally never edit it by hand.
CUSTOMER=acme                       # tenant slug: lowercase a-z 0-9 -, used as the compose project name
DOMAIN=acme.example.co.id           # the storefront hostname (routed by the shared proxy)
ACME_EMAIL=admin@example.co.id      # Let's Encrypt contact for this tenant's cert
NOP_VERSION=release-4.90.4

POSTGRES_DB=nopcommerce
POSTGRES_USER=nopapp
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# Optional: headless DB-connection seeding (default false -> run the install wizard once).
NOP_SEED_DATASETTINGS=false

# Optional: nightly db-backup retention (defaults applied if unset). Still copy /backups off-box.
# BACKUP_SCHEDULE=@daily
# BACKUP_KEEP_DAYS=7
# BACKUP_KEEP_WEEKS=4
# BACKUP_KEEP_MONTHS=6
