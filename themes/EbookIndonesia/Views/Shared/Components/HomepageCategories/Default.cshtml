@model IList<CategoryModel>

@using Nop.Core.Domain.Catalog

@*
    eBook Indonesia — homepage "Ebook store" filter chips.
    Renders nopCommerce's real "Show on home page" categories as chips; each links to that
    category's catalog page (admin: Catalog → Categories → edit → "Show on home page").
*@
@if (Model.Count > 0)
{
    <div class="xt-cta xt-ebook-chips" style="justify-content:flex-start;margin-bottom:24px;gap:8px;flex-wrap:wrap;">
        @foreach (var item in Model)
        {
            <a class="xt-chip" href="@(await NopUrl.RouteGenericUrlAsync<Category>(new { SeName = item.SeName }))">@item.Name</a>
        }
    </div>
}
